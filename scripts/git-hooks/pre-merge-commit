#!/usr/bin/env bash
set -euo pipefail

# Nazgul pre-merge-commit guard — parallel-unit verdict check. Blocks
# `git merge --no-ff` of a task unit whose manifest under nazgul/tasks/
# records a merged commit but is not yet Status: DONE.
#
# Identity is resolved from GITHEAD_<sha> environment variables, not
# GIT_REFLOG_ACTION: git's setenv(..., overwrite=0) only sets REFLOG_ACTION
# when absent, so a caller can pre-set it to claim an approved unit while
# merging different, unreviewed content. GITHEAD_<sha> keys are different:
# git names the variable itself after the actual merged commit's SHA (one
# per head being merged), so the key can't be relabeled — only extra decoy
# keys can be added alongside it. We therefore treat ANY GITHEAD_<sha> whose
# SHA is listed in a task manifest's ## Commits section as a candidate, and
# BLOCK if that task's Status is not DONE, so a decoy claiming an approved
# unit cannot mask the genuine, unapproved one. (MERGE_HEAD is not usable
# here: git only writes it for a stopped/conflicted or --no-commit merge,
# not for the clean auto-committed merges this guard runs on — confirmed
# empirically, git 2.48, ort strategy.)
#
# git pre-merge-commit contract: no argv, no stdin read, exit 0 = allow,
# nonzero = block (message on stderr).

REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null || echo "")"
[ -n "$REPO_ROOT" ] || exit 0

CONFIG="$REPO_ROOT/nazgul/config.json"
DISPATCH="$(cd "$(dirname "$0")" && pwd)/_dispatch.sh"

_dispatch_and_exit() {
  if [ -f "$DISPATCH" ]; then
    export CLAUDE_PROJECT_DIR="$REPO_ROOT"
    # shellcheck source=/dev/null
    source "$DISPATCH"
    dispatch_prior_hook pre-merge-commit
    exit $?
  fi
  exit 0
}

# Every check below reads config/manifests via jq/grep. No jq -> nothing
# downstream is safely readable -> degrade to allow immediately, before any
# config read.
command -v jq >/dev/null 2>&1 || _dispatch_and_exit

[ -f "$CONFIG" ] || _dispatch_and_exit

# `// true` would treat a literal `false` as falsy too (jq quirk), so compare
# explicitly — only an explicit `false` disables the guard.
GIT_HOOKS_ENABLED=$(jq -r 'if .guards.git_hooks == false then "false" else "true" end' "$CONFIG" 2>/dev/null || echo "true")
[ "$GIT_HOOKS_ENABLED" = "true" ] || _dispatch_and_exit

PARALLEL=$(jq -r '.execution.parallel // false' "$CONFIG" 2>/dev/null || echo "false")
[ "$PARALLEL" = "true" ] || _dispatch_and_exit

ENFORCE=$(jq -r 'if .execution.enforce.premerge_guard == false then "false" else "true" end' "$CONFIG" 2>/dev/null || echo "true")
[ "$ENFORCE" = "true" ] || _dispatch_and_exit

# Candidate merged-head SHAs: one GITHEAD_<sha> per head git is merging,
# name-keyed by the actual content hash. Any failure in this pipeline (jq
# choking on a hostile/unexpected env) -> treat as no candidates, same as
# "no merge in progress" -> degrade to allow.
CANDIDATE_SHAS_JSON=$(env | sed -nE 's/^GITHEAD_([0-9a-f]{40,64})=.*/\1/p' | jq -R -s 'split("\n") | map(select(length>0))' 2>/dev/null) || CANDIDATE_SHAS_JSON='[]'
[ "$(printf '%s' "$CANDIDATE_SHAS_JSON" | jq 'length' 2>/dev/null || echo 0)" -gt 0 ] || _dispatch_and_exit

# Map each candidate SHA to a task manifest via its ## Commits section — the
# per-task replacement for the old graph.json commit lookup. Checked across
# EVERY candidate (not just the first match) so a decoy GITHEAD_<sha> for a
# DONE unit can't mask a genuine, unapproved candidate also present in the
# same merge. Candidates matching no manifest are untracked/unrelated
# commits (ignored); a matched task whose Status is not DONE blocks.
UNIT_ID=""
STATUS=""
while IFS= read -r CANDIDATE_SHA; do
  [ -n "$CANDIDATE_SHA" ] || continue
  for tf in "$REPO_ROOT/nazgul/tasks"/TASK-*.md; do
    [ -f "$tf" ] || continue
    grep -A10 '^## Commits' "$tf" 2>/dev/null | grep -q "$CANDIDATE_SHA" || continue
    tf_status=$(grep -E '^\- \*\*Status\*\*:' "$tf" 2>/dev/null | head -1 | sed 's/^.*: *//' | tr -d ' ')
    if [ "$tf_status" != "DONE" ]; then
      UNIT_ID=$(basename "$tf" .md)
      STATUS="$tf_status"
      break 2
    fi
  done
done < <(printf '%s' "$CANDIDATE_SHAS_JSON" | jq -r '.[]' 2>/dev/null)

[ -n "$UNIT_ID" ] || _dispatch_and_exit

echo "NAZGUL GUARD: Blocked — merge includes $UNIT_ID (status='${STATUS:-none}'), which is not DONE; the review board has not approved it." >&2
exit 1
